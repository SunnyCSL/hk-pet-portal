---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="📰 寵物資訊" lang="zh">
  <div class="max-w-4xl mx-auto px-4 py-6 md:py-8">
    <h1 class="text-xl md:text-2xl font-bold text-near-black mb-1">📰 寵物資訊</h1>
    <p class="text-sm text-gray-400 mb-8">香港寵物相關最新消息、活動、政策更新</p>
    
    <div class="text-center py-16 bg-warm-white rounded-xl">
      <div class="text-4xl mb-3">📡</div>
      <p class="text-sm text-gray-500 mb-2">資訊自動搜集功能即將上線</p>
      <p class="text-xs text-gray-400">每日自動搜集香港寵物相關最新消息</p>
    </div>
  </div>
</BaseLayout>
