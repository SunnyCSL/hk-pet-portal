---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';

// Read health articles from pet-health-library
const healthDir = new URL('../../pet-health-library/content/health-articles/', import.meta.url);
import glob from 'node:fs';

const articles = [
  { emoji: '🥩', title: '狗狗營養缺乏症完整指南', desc: '症狀識別與補充方法', cat: 'nutrition', catName: '營養', date: 'Jul 7' },
  { emoji: '💆', title: '狗狗家居按摩治療基礎', desc: '放鬆肌肉與促進血液循環', cat: 'care', catName: '護理', date: 'Jul 7' },
  { emoji: '🥘', title: '狗狗鮮食營養指南', desc: '自煮鮮食的營養比例與食材選擇', cat: 'nutrition', catName: '營養', date: 'Jul 7' },
  { emoji: '🌿', title: '狗隻中醫五元素養生法', desc: '體質辨識與食療調理', cat: 'tcm', catName: '中醫', date: 'Jul 7' },
  { emoji: '🌸', title: '狗狗季節性中醫養生', desc: '春夏秋冬飲食調整要點', cat: 'tcm', catName: '中醫', date: 'Jul 7' },
  { emoji: '📊', title: '狗隻營養標準對比', desc: 'AAFCO vs NRC vs 鮮食營養學', cat: 'nutrition', catName: '營養', date: 'Jul 7' },
  { emoji: '🐕', title: '狗狗行為解讀手冊', desc: '從肢體語言了解毛孩心聲', cat: 'behavior', catName: '行為', date: 'Jul 7' },
  { emoji: '🆘', title: '狗狗急救應對手冊', desc: '家居常見意外處理與緊急護理', cat: 'care', catName: '護理', date: 'Jul 7' },
];

const catFilter = Astro.url.searchParams.get('cat') || '';
const filtered = catFilter ? articles.filter(a => a.cat === catFilter) : articles;

const categories = [
  { id: '', name: '全部', count: articles.length },
  { id: 'nutrition', name: '營養', count: articles.filter(a => a.cat === 'nutrition').length },
  { id: 'tcm', name: '中醫', count: articles.filter(a => a.cat === 'tcm').length },
  { id: 'care', name: '護理', count: articles.filter(a => a.cat === 'care').length },
  { id: 'behavior', name: '行為', count: articles.filter(a => a.cat === 'behavior').length },
];
---

<BaseLayout title="📚 健康圖書館" lang="zh">
  <div class="max-w-4xl mx-auto px-4 py-6 md:py-8">
    <h1 class="text-xl md:text-2xl font-bold text-near-black mb-1">📚 健康指南</h1>
    <p class="text-sm text-gray-400 mb-5">由專業寵物課程改編，經重新編寫加入原創內容與最新研究</p>

    <!-- Category pills -->
    <div class="overflow-x-auto -mx-4 px-4 mb-5 scrollbar-hide">
      <div class="flex gap-1.5 w-max md:w-auto">
        {categories.map((c: { id: string; name: string; count: number }) => (
          <a href={c.id ? `/health?cat=${c.id}` : '/health'}
            class={`shrink-0 px-3 py-1.5 rounded-full text-xs font-medium no-underline whitespace-nowrap transition-all ${
              catFilter === c.id ? 'bg-brand text-white' : 'bg-gray-50 text-gray-500 hover:bg-gray-100'
            }`}
          >{c.name} ({c.count})</a>
        ))}
      </div>
    </div>

    <!-- Article grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {filtered.map((a: { emoji: string; title: string; desc: string; cat: string; catName: string; date: string }) => (
        <a href={`/health/${a.title.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '')}`}
          class="group bg-white rounded-xl p-4 border border-gray-100 hover:border-brand/30 hover:shadow-sm transition-all no-underline"
        >
          <div class="flex items-start gap-3">
            <div class="text-2xl shrink-0 mt-0.5">{a.emoji}</div>
            <div class="min-w-0 flex-1">
              <h2 class="text-sm md:text-base font-semibold text-near-black group-hover:text-brand transition-colors leading-tight">
                {a.title}
              </h2>
              <p class="text-xs text-gray-400 mt-1">{a.desc}</p>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-[10px] bg-brand-light text-brand/80 px-2 py-0.5 rounded-full font-medium">{a.catName}</span>
                <span class="text-[10px] text-gray-300">{a.date}</span>
              </div>
            </div>
            <div class="text-gray-300 group-hover:text-brand transition-colors shrink-0 text-xs mt-1">→</div>
          </div>
        </a>
      ))}
    </div>

    {filtered.length === 0 && (
      <div class="text-center py-16 text-gray-400">
        <p class="text-sm">該分類暫時未有文章</p>
        <a href="/health" class="text-brand text-sm hover:underline mt-2 inline-block">睇全部文章</a>
      </div>
    )}
  </div>
</BaseLayout>
