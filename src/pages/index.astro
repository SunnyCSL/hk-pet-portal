---
import BaseLayout from '../layouts/BaseLayout.astro';
import stats from '../data/restaurant-stats.json';
import restaurants from '../data/restaurants.json';
import DistrictPills from '../components/DistrictPills.astro';
import StatsGrid from '../components/StatsGrid.astro';
import RestaurantsDealGrid from '../components/RestaurantsDealGrid.astro';
---

<BaseLayout title="HK Pet Portal" lang="zh">
  <!-- Hero — Direct Action Search -->
  <section class="pt-16 pb-20 bg-gradient-to-b from-brand-light to-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-near-black mb-2">
        🐾 帶毛孩・食盡香港
      </h1>
      <p class="text-sm text-gray-500 mb-6">
        全港 <strong class="text-brand font-semibold">{stats.total}</strong> 間狗友善餐廳
      </p>

      <!-- Quick search — direct action -->
      <form action="/restaurants" method="GET" class="max-w-md mx-auto">
        <div class="flex bg-white rounded-full shadow-sm border border-gray-100 p-1.5">
          <input
            type="text" name="q" list="suggestions"
            placeholder="搜尋餐廳、地區..."
            class="flex-1 px-4 text-sm outline-none border-none bg-transparent"
          />
          <button type="submit" class="bg-brand text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-green-700 transition-colors shrink-0">
            🔍 搜
          </button>
        </div>
      </form>

      <!-- District pills — direct action, no search needed -->
      <div class="mt-5">
        <DistrictPills restaurants={restaurants} lang="zh" />
      </div>
    </div>
  </section>

  <!-- Stats = Links (not decoration) -->
  <StatsGrid stats={stats} lang="zh" />

  <!-- Latest Deals — price-first grid -->
  <RestaurantsDealGrid restaurants={restaurants} lang="zh" />

  <!-- Health Library — compact grid -->
  <section class="max-w-4xl mx-auto px-4 mt-12">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-near-black">📚 健康指南</h2>
      <a href="/health" class="text-sm text-brand hover:text-green-700 no-underline font-medium">睇全部 →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <a href="/health/tcm" class="bg-warm-white rounded-xl p-4 text-center hover:bg-brand-light transition-colors no-underline group">
        <div class="text-2xl mb-1">🌿</div>
        <div class="text-sm font-medium text-gray-700 group-hover:text-brand">中醫養生</div>
        <div class="text-xs text-gray-400 mt-0.5">3 篇文章</div>
      </a>
      <a href="/health/nutrition" class="bg-warm-white rounded-xl p-4 text-center hover:bg-brand-light transition-colors no-underline group">
        <div class="text-2xl mb-1">🥩</div>
        <div class="text-sm font-medium text-gray-700 group-hover:text-brand">營養鮮食</div>
        <div class="text-xs text-gray-400 mt-0.5">3 篇文章</div>
      </a>
      <a href="/health/behavior" class="bg-warm-white rounded-xl p-4 text-center hover:bg-brand-light transition-colors no-underline group">
        <div class="text-2xl mb-1">🐕</div>
        <div class="text-sm font-medium text-gray-700 group-hover:text-brand">行為訓練</div>
        <div class="text-xs text-gray-400 mt-0.5">1 篇文章</div>
      </a>
      <a href="/health/care" class="bg-warm-white rounded-xl p-4 text-center hover:bg-brand-light transition-colors no-underline group">
        <div class="text-2xl mb-1">💆</div>
        <div class="text-sm font-medium text-gray-700 group-hover:text-brand">護理急救</div>
        <div class="text-xs text-gray-400 mt-0.5">3 篇文章</div>
      </a>
    </div>
  </section>

  <!-- Bottom spacer -->
  <div class="h-16"></div>
</BaseLayout>
