---
import BaseLayout from '../layouts/BaseLayout.astro';
import restaurants from '../data/restaurants.json';
import stats from '../data/restaurant-stats.json';

const districts = [...new Set(restaurants.map((r: { district: string }) => r.district))].sort();
---

<BaseLayout title="🍽️ 餐廳搜尋" lang="zh">
  <div class="max-w-4xl mx-auto px-4 py-6 md:py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-5">
      <div class="flex items-center gap-3">
        <h1 class="text-xl md:text-2xl font-bold text-near-black">🍽️ 狗友善餐廳</h1>
        <span class="text-sm text-gray-400 bg-gray-50 px-2.5 py-0.5 rounded-full" id="result-count">{restaurants.length} 間</span>
      </div>
      <a href="/restaurants" class="text-xs text-gray-400 hover:text-brand no-underline hidden" id="clear-filter">清除篩選</a>
    </div>

    <!-- Search bar -->
    <div class="flex gap-2 mb-5">
      <div class="flex-1 flex gap-2">
        <input type="text" id="search-input" placeholder="搜尋餐廳、地區..."
          class="flex-1 min-w-0 px-3.5 py-2 text-sm border border-gray-100 rounded-lg outline-none focus:border-brand/50 bg-white"
        />
        <button onclick="filterList()" class="bg-brand text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition-colors shrink-0">🔍</button>
      </div>
    </div>

    <!-- District pills — clickable, triggers JS filter -->
    <div class="overflow-x-auto -mx-4 px-4 mb-5 scrollbar-hide">
      <div class="flex gap-1.5 w-max md:w-auto md:flex-wrap">
        <a href="/restaurants" onclick="setDistrict(''); return false;"
          class="shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-all no-underline whitespace-nowrap bg-brand text-white"
          id="pill-all">全部</a>
        {districts.map((d: string) => (
          <a href={`/restaurants?district=${encodeURIComponent(d)}`} onclick={`setDistrict('${d}'); return false;`}
            class="shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-all no-underline whitespace-nowrap bg-gray-50 text-gray-500 hover:bg-gray-100"
            id={`pill-${d.replace(/\s/g, '')}`}
          >{d}</a>
        ))}
      </div>
    </div>

    <!-- Results list -->
    <div id="restaurant-list" class="flex flex-col gap-2">
      {restaurants.map((r: { id: number; name_zh: string; name_en: string; district: string; address: string }) => (
        <a href={`/restaurants/${r.id}`}
          class="restaurant-item group bg-white rounded-xl px-4 py-3 border border-gray-100 hover:border-brand/30 hover:shadow-sm transition-all no-underline"
          data-name={(r.name_zh || r.name_en || '').toLowerCase()}
          data-district={r.district}
        >
          <div class="flex items-center gap-3">
            <div class="w-1 h-10 bg-brand/20 rounded-full shrink-0"></div>
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-sm md:text-base text-near-black group-hover:text-brand transition-colors truncate">
                {r.name_zh || r.name_en || `${r.district}狗友善餐廳`}
              </h3>
              <p class="text-xs text-gray-400 mt-0.5 truncate">
                <span class="inline-flex items-center gap-1">
                  <span class="text-gray-300">📍</span> <span class="sub-area-label" data-addr={r.address} data-name={r.name_zh||''}>{r.district}</span>
                </span>
                <span class="mx-1.5 text-gray-200">·</span>
                <span class="text-gray-300">{r.address}</span>
              </p>
            </div>
            <div class="text-gray-300 group-hover:text-brand transition-colors shrink-0">
              <span class="text-xs">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="text-center py-16 text-gray-400 hidden">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-sm">搵唔到相關餐廳</p>
      <a href="/restaurants" onclick="resetFilter(); return false;" class="text-brand text-sm hover:underline mt-2 inline-block">清除篩選重新搜尋</a>
    </div>
  </div>

  <script is:inline>
  // Sub-area detection from address
  var SUB_AREAS = [
    ['馬鞍山',0],['科學園',0],['白石角',0],
    ['香港仔',0],['黃竹坑',0],['海洋公園',0],['淺水灣',0],['赤柱',0],['薄扶林',0],['數碼港',0],['鴨脷洲',0],
    ['中環',0],['上環',0],['西營盤',0],['堅尼地城',0],['石塘咀',0],['半山',0],['山頂',0],['金鐘',0],
    ['銅鑼灣',0],['跑馬地',0],['大坑',0],['天后',0],
    ['北角',0],['鰂魚涌',0],['太古',0],['西灣河',0],['筲箕灣',0],['柴灣',0],
    ['尖沙咀',0],['尖東',0],['佐敦',0],['油麻地',0],
    ['旺角',0],['太子',0],['大角咀',0],
    ['長沙灣',0],['荔枝角',0],['美孚',0],
    ['土瓜灣',0],['紅磡',0],['何文田',0],['啟德',0],
    ['九龍灣',0],['觀塘',0],['牛頭角',0],['藍田',0],['油塘',0],
    ['深井',0],['馬灣',0],['荃灣',0],
    ['屯門',0],['黃金海岸',0],
    ['元朗',0],['天水圍',0],['錦田',0],
    ['上水',0],['粉嶺',0],
    ['大埔',0],
    ['沙田',0],['大圍',0],['火炭',0],
    ['西貢',0],['將軍澳',0],['坑口',0],['寶琳',0],['調景嶺',0],['康城',0],['清水灣',0],
    ['葵涌',0],['葵芳',0],['青衣',0],
    ['東涌',0],['愉景灣',0],['迪士尼',0],['機場',0],['大澳',0],['長洲',0],['南丫島',0],['坪洲',0],
  ];

  function detectSubArea(addr, name) {
    var combined = (addr || '') + ' ' + (name || '');
    for (var i = 0; i < SUB_AREAS.length; i++) {
      if (combined.indexOf(SUB_AREAS[i][0]) !== -1) {
        return SUB_AREAS[i][0];
      }
    }
    return null;
  }

  // Apply sub-area labels
  document.querySelectorAll('.sub-area-label').forEach(function(el) {
    var addr = el.getAttribute('data-addr') || '';
    var name = el.getAttribute('data-name') || '';
    var sub = detectSubArea(addr, name);
    if (sub) el.textContent = sub;
  });
  function filterList() {
    var q = (document.getElementById('search-input').value || '').toLowerCase();
    var items = document.querySelectorAll('.restaurant-item');
    var count = 0;
    var activeDistrict = document.querySelector('[data-active-district]');
    var district = activeDistrict ? activeDistrict.getAttribute('data-active-district') : '';

    items.forEach(function(el) {
      var name = el.getAttribute('data-name') || '';
      var itemDistrict = el.getAttribute('data-district') || '';
      var match = true;

      if (district && itemDistrict !== district) match = false;
      if (q && !name.includes(q) && !itemDistrict.includes(q)) match = false;

      el.style.display = match ? '' : 'none';
      if (match) count++;
    });

    document.getElementById('result-count').textContent = count + ' 間';
    document.getElementById('empty-state').classList.toggle('hidden', count > 0);
    document.getElementById('clear-filter').classList.toggle('hidden', !district && !q);
  }

  function setDistrict(d) {
    // Update pill styles
    document.querySelectorAll('[id^="pill-"]').forEach(function(el) {
      el.className = el.className.replace(/bg-brand text-white/g, 'bg-gray-50 text-gray-500');
    });
    if (d) {
      var pill = document.getElementById('pill-' + d.replace(/\s/g, ''));
      if (pill) pill.className = pill.className.replace(/bg-gray-50 text-gray-500/g, 'bg-brand text-white');
    } else {
      document.getElementById('pill-all').className = document.getElementById('pill-all').className.replace(/bg-gray-50 text-gray-500/g, 'bg-brand text-white');
    }

    // Store active district
    document.querySelectorAll('[data-active-district]').forEach(function(el) { el.removeAttribute('data-active-district'); });
    if (d) document.body.setAttribute('data-active-district', d);

    filterList();
  }

  function resetFilter() {
    document.getElementById('search-input').value = '';
    setDistrict('');
  }

  // On page load, apply filter from URL
  window.addEventListener('DOMContentLoaded', function() {
    var params = new URLSearchParams(window.location.search);
    var q = params.get('q');
    var d = params.get('district');

    if (q) document.getElementById('search-input').value = q;
    if (d) setDistrict(d);
    if (q || d) filterList();
  });
  </script>
</BaseLayout>
