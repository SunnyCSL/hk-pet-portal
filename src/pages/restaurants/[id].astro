---
import BaseLayout from '../../layouts/BaseLayout.astro';
import restaurants from '../../data/restaurants.json';
import coords from '../../data/restaurant-coords.json';

export async function getStaticPaths() {
  return restaurants.map((r: { id: number }) => ({
    params: { id: String(r.id) },
    props: { restaurant: r },
  }));
}

const { id } = Astro.params;
const { restaurant } = Astro.props;

if (!restaurant) {
  return Astro.redirect('/404');
}

// Related restaurants (same district, random 3)
const related = restaurants
  .filter((r: { id: number; district: string }) => r.district === restaurant.district && r.id !== restaurant.id)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

const displayName = restaurant.name_zh || restaurant.name_en || `${restaurant.district}狗友善餐廳`;

// Get pre-geocoded coordinates from HK Gov API
const restCoords = coords[restaurant.id] || null;
const restLat = restCoords?.lat || 22.3193;
const restLng = restCoords?.lng || 114.1694;
---

<BaseLayout title={displayName} lang="zh">
  <div class="max-w-3xl mx-auto px-4 py-6 md:py-8">
    <!-- Back link -->
    <a href="/restaurants" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-brand no-underline mb-4">
      ← 餐廳列表
    </a>

    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-near-black leading-tight">{displayName}</h1>
      {restaurant.name_zh && restaurant.name_en && restaurant.name_en !== restaurant.name_zh && (
        <p class="text-sm text-gray-400 mt-1">{(restaurant.name_zh ? restaurant.name_en : '')}</p>
      )}
      <div class="flex flex-wrap items-center gap-2 mt-3">
        <span class="inline-flex items-center gap-1 text-xs bg-brand-light text-brand px-2.5 py-1 rounded-full font-medium">
          📍 <span class="sub-area-label" data-addr={restaurant.address} data-name={displayName}>{restaurant.district}</span>
        </span>
        <span class="inline-flex items-center gap-1 text-xs bg-gray-50 text-gray-500 px-2.5 py-1 rounded-full">
          🐾 狗友善餐廳
        </span>
        <span class="inline-flex items-center gap-1 text-xs bg-gray-50 text-gray-500 px-2.5 py-1 rounded-full">
          🪪 {restaurant.license_no}
        </span>
      </div>
    </div>

    <!-- Address + Interactive Map -->
    <div class="bg-white rounded-xl border border-gray-100 overflow-hidden mb-4">
      <div class="p-4 md:p-5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">地址</h2>
        <p class="text-sm md:text-base text-near-black">{restaurant.address}</p>
      </div>
      <!-- Leaflet Map --->
      <div id="restaurant-map" class="h-48 md:h-64 bg-gray-50" data-lat={restLat} data-lng={restLng} data-name={displayName} data-address={restaurant.address}></div>
      <div class="px-4 md:px-5 pb-4 pt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-400">
        <a href={`https://www.google.com/maps/search/${encodeURIComponent(restaurant.address + ' Hong Kong')}`}
          target="_blank"
          class="inline-flex items-center gap-1 text-brand hover:underline"
        >
          🗺️ Google Maps 搵路 →
        </a>
        <span class="text-gray-200">·</span>
        <a href={`https://www.openrice.com/zh/hongkong/restaurants?where=${encodeURIComponent((restaurant.name_zh || restaurant.name_en || '').trim())}`}
          target="_blank"
          class="inline-flex items-center gap-1 text-gray-500 hover:text-orange-500 hover:underline"
        >
          📖 OpenRice →
        </a>
        <span class="text-gray-200">·</span>
        <span>拖動地圖・放大縮細</span>
      </div>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
    <script is:inline>
    // Sub-area detection
    var SUB_AREAS = ['馬鞍山','科學園','白石角','香港仔','黃竹坑','海洋公園','淺水灣','赤柱','薄扶林','數碼港','鴨脷洲','中環','上環','西營盤','堅尼地城','石塘咀','半山','山頂','金鐘','銅鑼灣','跑馬地','大坑','天后','北角','鰂魚涌','太古','西灣河','筲箕灣','柴灣','尖沙咀','尖東','佐敦','油麻地','旺角','太子','大角咀','長沙灣','荔枝角','美孚','土瓜灣','紅磡','何文田','啟德','九龍灣','觀塘','牛頭角','藍田','油塘','深井','馬灣','荃灣','屯門','黃金海岸','元朗','天水圍','錦田','上水','粉嶺','大埔','沙田','大圍','火炭','西貢','將軍澳','坑口','寶琳','調景嶺','康城','清水灣','葵涌','葵芳','青衣','東涌','愉景灣','迪士尼','機場','大澳','長洲','南丫島','坪洲','馬鞍山'];
    document.querySelectorAll('.sub-area-label').forEach(function(el) {
      var addr = el.getAttribute('data-addr') || '';
      var name = el.getAttribute('data-name') || '';
      var combined = addr + ' ' + name;
      for (var i = 0; i < SUB_AREAS.length; i++) {
        if (combined.indexOf(SUB_AREAS[i]) !== -1) {
          el.textContent = SUB_AREAS[i];
          break;
        }
      }
    });
    document.addEventListener('DOMContentLoaded', function() {
      var mapEl = document.getElementById('restaurant-map');
      if (!mapEl || typeof L === 'undefined') { console.log('Leaflet not loaded'); return; }

      var lat = parseFloat(mapEl.getAttribute('data-lat')) || 22.3193;
      var lng = parseFloat(mapEl.getAttribute('data-lng')) || 114.1694;
      var name = mapEl.getAttribute('data-name') || '';
      var address = mapEl.getAttribute('data-address') || '';

      var map = L.map(mapEl, {
        center: [lat, lng],
        zoom: 16,
        zoomControl: true,
        scrollWheelZoom: true
      });

      L.tileLayer('https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; CARTO &copy; OpenStreetMap',
        maxZoom: 19
      }).addTo(map);

      L.marker([lat, lng]).addTo(map)
        .bindPopup('<strong>' + name + '</strong><br>' + address)
        .openPopup();

      setTimeout(function() { map.invalidateSize(); }, 200);
    });
    </script>

    <!-- FEHD License info -->
    <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 mb-6">
      <h2 class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-1">牌照資料</h2>
      <p class="text-xs text-amber-600 leading-relaxed">
        此餐廳已獲食環署批准容許狗隻進入。<br />
        牌照號碼：<strong>{restaurant.license_no}</strong>
      </p>
      <a href="https://www.fehd.gov.hk/tc_chi/licensing/license_general_restaurant_dog.html"
        target="_blank"
        class="inline-flex items-center gap-1 text-xs text-amber-600 hover:underline mt-1.5"
      >
        🔗 食環署官方名單 ↗
      </a>
    </div>

    <!-- Related restaurants -->
    {related.length > 0 && (
      <div class="mt-8 pt-6 border-t border-gray-100">
        <h2 class="text-sm font-semibold text-gray-500 mb-3">同區其他狗友善餐廳</h2>
        <div class="flex flex-col gap-2">
          {related.map((r: { id: number; name_zh: string; name_en: string; district: string }) => (
            <a href={`/restaurants/${r.id}`}
              class="group bg-white rounded-xl px-4 py-3 border border-gray-100 hover:border-brand/30 transition-all no-underline"
            >
              <div class="flex items-center justify-between gap-2">
                <div class="min-w-0 flex-1">
                  <h3 class="text-sm font-medium text-near-black group-hover:text-brand transition-colors truncate">
                    {r.name_zh || r.name_en}
                  </h3>
                </div>
                <span class="text-xs text-gray-300 group-hover:text-brand transition-colors shrink-0">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
